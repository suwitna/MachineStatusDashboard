	/* ==========================================================================================
	 * SECTION 6: DRAG & DROP & CONTROL SUB-FUNCTIONS
	 * ========================================================================================== */
	window.updateProp = function(idx, type, val) {
		// Event handler syncing right sidebar property modifications back to memory models
		if (!machines[idx]) return;

		if (type === 'boxW') machines[idx].labelW = parseInt(val) || 125;
		if (type === 'boxH') machines[idx].labelH = parseInt(val) || 24;
		if (type === 'size') machines[idx].fontSize = parseFloat(val) || 11.0;
		if (type === 'color') machines[idx].colorCode = val;
		if (type === 'loc') machines[idx].resourceLocation = val;
		if (type === 'weight') machines[idx].fontWeight = val;

		if (type === 'rectype') machines[idx].recordType = (val === 'NULL' || !val) ? null : val;
		if (type === 'status') machines[idx].status = (val === 'NULL' || !val) ? null : val;
		if (type === 'reqdate') machines[idx].requestDate = val;

		calculateBoundaries(machines[idx]); // Recomputes fluid bounds post configuration updates
		render();
	}

	function initiateDrag(evt) {
		evt.preventDefault();
		evt.stopPropagation(); 
	
		activeMacId = evt.target.getAttribute('data-id');
		activeDragType = evt.target.getAttribute('data-role');
		activeElement = machines.find(m => m.id === activeMacId);

		window.lastMousePos = { x: evt.clientX, y: evt.clientY }; // Caches viewport drag cursor anchors

		document.addEventListener('mousemove', executeDrag);
		document.addEventListener('mouseup', terminateDrag);
	}

	function executeDrag(evt) {
		if (!activeElement) return;

		const currentImgW = imgW || BG_IMG_WIDTH;
		const currentImgH = imgH || BG_IMG_HEIGHT;

		if (!window.lastMousePos) return;
		// Scales drag metrics inverse to current zoom levels to preserve raw mouse tracing speed
		const deltaX = (evt.clientX - window.lastMousePos.x) / scale;
		const deltaY = (evt.clientY - window.lastMousePos.y) / scale;

		window.lastMousePos = { x: evt.clientX, y: evt.clientY };

		if (activeDragType === 'label') {
			// Shifts the global bounding wrapper framework directly
			const shiftPctX = (deltaX / currentImgW) * 100;
			const shiftPctY = (deltaY / currentImgH) * 100;

			activeElement.leftPct = parseFloat((activeElement.leftPct + shiftPctX).toFixed(2));
			activeElement.topPct = parseFloat((activeElement.topPct + shiftPctY).toFixed(2));
		} else if (activeDragType === 'arrow-start') {
			// Mutates localized inner vector positions
			activeElement.startX = Math.round(activeElement.startX + deltaX);
			activeElement.startY = Math.round(activeElement.startY + deltaY);
			calculateBoundaries(activeElement);
		} else if (activeDragType === 'arrow-tip') {
			activeElement.tipX = Math.round(activeElement.tipX + deltaX);
			activeElement.tipY = Math.round(activeElement.tipY + deltaY);
			calculateBoundaries(activeElement);
		}

		render();
	}

	function terminateDrag() { 
		activeElement = null; 
		document.removeEventListener('mousemove', executeDrag); 
		document.removeEventListener('mouseup', terminateDrag); 
	}

	function getSVGCoordinates(evt) {
		// Utility mapping raw client screen values directly down into standard CTM coordinates
		const point = svgOverlay.createSVGPoint();
		point.x = evt.clientX; point.y = evt.clientY;
		return point.matrixTransform(svgOverlay.getScreenCTM().inverse());
	}

	window.deleteMachine = function(idx) { 
		if (confirm("Are you sure you want to remove this resource from the workspace?")) {
			machines.splice(idx, 1); 
			render(); 
		}
	}

	// Clipboard Copy Event Listeners
	document.getElementById('btn-copy-sql').addEventListener('click', function() {
		navigator.clipboard.writeText(document.getElementById('output-sql').innerText)
			.then(() => alert('📋 SQL script copied to clipboard successfully!'));
	});

	document.getElementById('btn-copy-mock').addEventListener('click', function() {
		navigator.clipboard.writeText(document.getElementById('output-mock').innerText)
			.then(() => alert('📦 Mock data objects copied to clipboard successfully!'));
	});
</script>