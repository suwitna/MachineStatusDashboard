			const angle = Math.atan2(mac.tipY - mac.startY, mac.tipX - mac.startX);
			const baseLength = 8;
			const bLeftX = mac.tipX - baseLength * Math.cos(angle - Math.PI / 6);
			const bLeftY = mac.tipY - baseLength * Math.sin(angle - Math.PI / 6);
			const bRightX = mac.tipX - baseLength * Math.cos(angle + Math.PI / 6);
			const bRightY = mac.tipY - baseLength * Math.sin(angle + Math.PI / 6);
			const pointsString = `${mac.tipX},${mac.tipY} ${bLeftX.toFixed(1)},${bLeftY.toFixed(1)} ${bRightX.toFixed(1)},${bRightY.toFixed(1)}`;
        
